{
  "name": "@brain-garden/appwrite-migrations",
  "version": "1.0.0",
  "description": "Database migration system for Appwrite in Brain Garden",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./runner": "./src/runner.ts",
    "./types": "./src/types.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "clean": "rimraf node_modules .turbo",
    "format": "biome format . --check",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage"
  },
  "dependencies": {
    "@brain-garden/core-appwrite": "workspace:*",
    "appwrite": "^16.0.2",
    "chalk": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@kit/testing": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "vitest": "^2.1.8"
  }
}
