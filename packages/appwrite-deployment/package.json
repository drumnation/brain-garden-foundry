{
  "name": "@brain-garden/appwrite-deployment",
  "version": "1.0.0",
  "description": "REAL Appwrite deployment integration for Brain Garden template",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "brain-garden-deploy": "./src/cli.ts"
  },
  "scripts": {
    "test": "npx vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "npx vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "deploy:test": "tsx ./src/cli.ts test",
    "deploy:provision": "tsx ./src/cli.ts provision"
  },
  "dependencies": {
    "appwrite": "^16.0.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@vitest/ui": "^2.1.4",
    "node-fetch": "^3.3.2",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "appwrite",
    "deployment",
    "brain-garden",
    "baas",
    "infrastructure"
  ],
  "author": "Brain Garden Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/brain-garden-monorepo-template"
  },
  "files": [
    "src",
    "README.md"
  ]
}
