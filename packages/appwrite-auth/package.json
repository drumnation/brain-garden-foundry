{
  "name": "@brain-garden/appwrite-auth",
  "version": "1.0.0",
  "description": "Authentication service layer for Appwrite integration",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./service": "./src/auth.service.ts",
    "./hooks": "./src/auth.hooks.ts",
    "./store": "./src/auth.store.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "clean": "rimraf node_modules .turbo",
    "format": "biome format . --check",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@brain-garden/core-appwrite": "workspace:*",
    "appwrite": "^16.0.2",
    "zustand": "^5.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@kit/testing": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "react": "^18.3.1",
    "vitest": "^2.1.8"
  }
}
