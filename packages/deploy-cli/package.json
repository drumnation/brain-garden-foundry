{
  "name": "@brain-garden/deploy-cli",
  "version": "1.0.0",
  "description": "Effortless deployment CLI for Brain Garden monorepo template",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./commands": "./src/commands/index.ts",
    "./utils": "./src/utils/index.ts"
  },
  "bin": {
    "brain-deploy": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "clean": "rimraf node_modules .turbo",
    "format": "biome format . --check",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@brain-garden/core-appwrite": "workspace:*",
    "@brain-garden/appwrite-migrations": "workspace:*",
    "appwrite": "^16.0.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@kit/testing": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.20.3",
    "vitest": "^2.1.8"
  }
}
