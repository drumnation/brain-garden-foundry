{
  "name": "brain-garden-monorepo-template",
  "version": "1.0.0",
  "description": "Production-ready monorepo template with generator-first approach for Express API, React apps, and complete Brain Garden tooling",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "concurrently \"turbo run dev\" \"pnpm storybook\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:storybook": "test-storybook",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm build-storybook --quiet && npx http-server storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && pnpm test:storybook\"",
    "test:e2e:browser": "turbo run test:e2e:browser",
    "validate": "turbo run validate",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "monitor:dev": "node tooling/brain-monitor/cli.mjs dev",
    "monitor:errors": "node tooling/brain-monitor/cli.mjs errors",
    "monitor:logs": "node tooling/brain-monitor/cli.mjs logs",
    "brain:validate": "brain-monitor validate",
    "brain:watch": "brain-monitor watch",
    "brain:check": "cat _errors/validation-summary.md",
    "brain:typecheck-failures": "brain-monitor typecheck",
    "brain:lint-failures": "brain-monitor lint",
    "brain:format-failures": "brain-monitor format",
    "brain:test-failures-unit": "brain-monitor test unit",
    "brain:test-failures-integration": "brain-monitor test integration",
    "brain:test-failures-e2e": "brain-monitor test e2e",
    "brain:logs": "brain-monitor logs",
    "brain:dev": "brain-monitor dev",
    "ci:init": "brain-monitor ci:init",
    "generate:all-apps": "pnpm gen:react-web && pnpm gen:react-native && pnpm gen:electron && pnpm gen:express-api && pnpm gen:library && pnpm setup:mega-template",
    "setup:mega-template": "tsx scripts/post-generate-setup.ts",
    "setup:mega": "tsx tooling/generators/mega-setup/index.ts",
    "validate:template": "tsx scripts/validate-template.ts",
    "rules:build": "tsx .cursor/sync/build-consolidated-rules.ts",
    "rules:build:strict": "tsx .cursor/sync/build-consolidated-rules.ts --strict",
    "rules:verify": "tsx scripts/verify-rule-distribution.ts",
    "rules:analyze": "tsx scripts/analyze-rule-sizes.ts",
    "rules:build:verify": "pnpm rules:build && pnpm rules:verify",
    "rules:full-check": "pnpm rules:analyze && pnpm rules:build:verify",
    "rules:watch": "tsx watch --watch-path=.brain/rules .cursor/sync/build-consolidated-rules.ts",
    "dev:with-rules": "pnpm setup:env && concurrently \"pnpm rules:watch\" \"cross-env FORCE_COLOR=1 turbo dev --parallel\"",
    "generate": "plop",
    "gen:init": "tsx tooling/generators/init-monorepo/index.ts",
    "gen:react-web": "tsx tooling/generators/create-react-web/index.ts",
    "gen:react-native": "tsx tooling/generators/create-react-native/index.ts",
    "gen:electron": "tsx tooling/generators/create-electron/index.ts",
    "gen:express-api": "tsx tooling/generators/create-express-api/index.ts",
    "gen:library": "tsx tooling/generators/create-library/index.ts",
    "deploy:init": "pnpm --filter=@brain-garden/deploy-cli run dev init",
    "deploy:sync": "pnpm --filter=@brain-garden/deploy-cli run dev sync",
    "deploy:status": "pnpm --filter=@brain-garden/deploy-cli run dev status",
    "deploy:destroy": "pnpm --filter=@brain-garden/deploy-cli run dev destroy",
    "deploy:quick": "tsx scripts/quick-deploy.ts"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-coverage": "^3.0.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-storysource": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "^8.6.14",
    "@storybook/test-runner": "^0.24.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "axe-playwright": "^2.0.3",
    "concurrently": "^9.2.1",
    "execa": "^9.5.2",
    "glob": "^11.0.0",
    "http-server": "^14.1.1",
    "plop": "^4.0.4",
    "prompts": "^2.4.2",
    "rimraf": "^5.0.5",
    "storybook": "8.6.14",
    "tsx": "^4.20.3",
    "turbo": "^2.0.0",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.3"
  }
}
