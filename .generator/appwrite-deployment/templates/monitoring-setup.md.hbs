## 🔧 Technical Implementation

### Step 1: Pre-Flight Validation

```bash
#!/bin/bash

# Validate SSH connection
ssh -i {{security.sshKeyPath}} root@$VPS_IP "echo 'SSH connection successful'"

# Check Docker is running (required for monitoring stack)
ssh -i {{security.sshKeyPath}} root@$VPS_IP "docker --version"

# Check available disk space (need {{monitoring.storageSize}}+ for metrics storage)
DISK_AVAILABLE=$(ssh -i {{security.sshKeyPath}} root@$VPS_IP "df -h /var/lib/docker | awk 'NR==2 {print \$4}'")

# Validate Appwrite is running
curl -f "https://{{domain.appwriteSubdomain}}.{{domain.rootDomain}}/v1/health/version" || {
  echo "ERROR: Appwrite is not accessible"
  exit 1
}

# Check ports are available
for PORT in {{monitoring.prometheusPort}} {{monitoring.grafanaPort}} {{monitoring.alertmanagerPort}} {{monitoring.nodeExporterPort}} {{monitoring.cadvisorPort}}; do
  ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo lsof -i :$PORT" && {
    echo "ERROR: Port $PORT is already in use"
    exit 1
  }
done
```

