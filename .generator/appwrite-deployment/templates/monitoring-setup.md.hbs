### Step 8: Validate Monitoring Stack

Run comprehensive health checks:

```bash
#!/bin/bash

echo "=== Monitoring Stack Health Check ==="

# Check Prometheus
PROMETHEUS_HEALTH=$(curl -s http://$VPS_IP:{{monitoring.prometheusPort}}/-/healthy)
if [ "$PROMETHEUS_HEALTH" == "Prometheus is Healthy." ]; then
  echo "✅ Prometheus is healthy"
else
  echo "❌ Prometheus health check failed"
  exit 1
fi

# Check Grafana
GRAFANA_HEALTH=$(curl -s http://$VPS_IP:{{monitoring.grafanaPort}}/api/health | jq -r '.database')
if [ "$GRAFANA_HEALTH" == "ok" ]; then
  echo "✅ Grafana is healthy"
else
  echo "❌ Grafana health check failed"
  exit 1
fi

# Check Alertmanager
ALERTMANAGER_HEALTH=$(curl -s http://$VPS_IP:{{monitoring.alertmanagerPort}}/-/healthy)
if [ "$ALERTMANAGER_HEALTH" == "OK" ]; then
  echo "✅ Alertmanager is healthy"
else
  echo "❌ Alertmanager health check failed"
  exit 1
fi

# Verify all exporters are reachable
for exporter in node-exporter:{{monitoring.nodeExporterPort}} cadvisor:{{monitoring.cadvisorPort}} mariadb-exporter:9104 redis-exporter:9121; do
  name=$(echo $exporter | cut -d: -f1)
  port=$(echo $exporter | cut -d: -f2)

  if curl -sf http://$VPS_IP:$port/metrics > /dev/null; then
    echo "✅ $name is exporting metrics"
  else
    echo "❌ $name is not reachable"
    exit 1
  fi
done

# Check Prometheus is scraping all targets
TARGETS=$(curl -s http://$VPS_IP:{{monitoring.prometheusPort}}/api/v1/targets | jq -r '.data.activeTargets | length')
echo "📊 Prometheus is monitoring $TARGETS targets"

# Check Grafana dashboards
DASHBOARDS=$(curl -s http://admin:$GRAFANA_ADMIN_PASSWORD@$VPS_IP:{{monitoring.grafanaPort}}/api/search | jq -r 'length')
echo "📊 Grafana has $DASHBOARDS dashboards installed"

# Check active alerts
ALERTS=$(curl -s http://$VPS_IP:{{monitoring.prometheusPort}}/api/v1/alerts | jq -r '.data.alerts | length')
echo "🚨 $ALERTS active alerts"

echo "=== Monitoring Stack is Operational ==="
```

