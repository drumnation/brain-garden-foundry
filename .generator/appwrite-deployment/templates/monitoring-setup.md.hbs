### Step 7: Configure Log Aggregation

Create centralized logging directory:

```bash
ssh -i {{security.sshKeyPath}} root@$VPS_IP "
  sudo mkdir -p /var/log/appwrite/{api,realtime,workers,database}
  sudo chown -R 1000:1000 /var/log/appwrite
"
```

Configure Docker logging driver for Appwrite containers:

```bash
# Update Appwrite docker-compose.yml to use JSON file logging
ssh -i {{security.sshKeyPath}} root@$VPS_IP "
  cd /root/appwrite

  # Add logging configuration to docker-compose.yml
  cat >> docker-compose.yml <<'DOCKER_EOF'
x-logging: &default-logging
  driver: json-file
  options:
    max-size: '{{monitoring.logMaxSize}}'
    max-file: '{{monitoring.logMaxFiles}}'
    labels: 'service'
DOCKER_EOF

  # Add logging to all services
  sed -i '/^  [a-z-]*:/a\    logging: *default-logging' docker-compose.yml

  # Restart services with new logging config
  docker-compose up -d
"
```

Create log rotation script:

```bash
cat <<'EOF' | ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo tee /usr/local/bin/rotate-appwrite-logs.sh"
#!/bin/bash

# Rotate Appwrite Docker container logs
LOG_DIR="/var/log/appwrite"
RETENTION_DAYS={{monitoring.logRetentionDays}}

# Find and compress logs older than 1 day
find "$LOG_DIR" -name "*.log" -mtime +1 -exec gzip {} \;

# Delete compressed logs older than retention period
find "$LOG_DIR" -name "*.log.gz" -mtime +$RETENTION_DAYS -delete

# Truncate current container logs if > {{monitoring.logMaxSize}}
docker ps --format '{{verbatim}}{{.Names}}{{/verbatim}}' | grep appwrite | while read container; do
  LOG_FILE=$(docker inspect $container --format='{{verbatim}}{{.LogPath}}{{/verbatim}}')
  LOG_SIZE=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)

  if [ "$LOG_SIZE" -gt 104857600 ]; then
    echo "Truncating $container log (size: $LOG_SIZE bytes)"
    : > "$LOG_FILE"
  fi
done

echo "Log rotation completed at $(date)"
EOF

# Make script executable
ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo chmod +x /usr/local/bin/rotate-appwrite-logs.sh"

# Add cron job for daily log rotation
ssh -i {{security.sshKeyPath}} root@$VPS_IP "
  (crontab -l 2>/dev/null; echo '{{monitoring.logRotationCron}} /usr/local/bin/rotate-appwrite-logs.sh >> /var/log/log-rotation.log 2>&1') | crontab -
"
```

