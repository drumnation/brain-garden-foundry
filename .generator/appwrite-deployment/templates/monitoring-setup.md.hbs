### Step 2: Deploy Prometheus (Metrics Collection)

Create Prometheus configuration on VPS:

```bash
# Create monitoring directory structure
ssh -i {{security.sshKeyPath}} root@$VPS_IP "
  sudo mkdir -p /opt/monitoring/{prometheus,grafana,alertmanager}
  sudo mkdir -p /var/lib/prometheus
  sudo chown -R 65534:65534 /var/lib/prometheus
"

# Create prometheus.yml configuration
cat <<'EOF' | ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo tee /opt/monitoring/prometheus/prometheus.yml"
global:
  scrape_interval: {{monitoring.scrapeInterval}}
  evaluation_interval: {{monitoring.scrapeInterval}}
  external_labels:
    cluster: '{{projectName}}-production'
    environment: 'production'

# Alertmanager configuration
alerting:
  alertmanagers:
    - static_configs:
        - targets: ['alertmanager:{{monitoring.alertmanagerPort}}']

# Load alert rules
rule_files:
  - '/etc/prometheus/alerts/*.yml'

# Scrape configurations
scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{monitoring.prometheusPort}}']

  # Appwrite API health endpoint
  - job_name: 'appwrite-api'
    metrics_path: '/health/metrics'
    static_configs:
      - targets: ['appwrite:80']
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        replacement: 'appwrite-api'

  # Appwrite Realtime service
  - job_name: 'appwrite-realtime'
    static_configs:
      - targets: ['appwrite-realtime:80']

  # MariaDB metrics (via mysqld_exporter)
  - job_name: 'mariadb'
    static_configs:
      - targets: ['mariadb-exporter:9104']

  # Redis metrics (via redis_exporter)
  - job_name: 'redis'
    static_configs:
      - targets: ['redis-exporter:9121']

  # Node exporter (system metrics)
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:{{monitoring.nodeExporterPort}}']

  # cAdvisor (container metrics)
  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:{{monitoring.cadvisorPort}}']

  # Appwrite workers
  - job_name: 'appwrite-workers'
    static_configs:
      - targets:
          - 'appwrite-worker-audits:80'
          - 'appwrite-worker-webhooks:80'
          - 'appwrite-worker-deletes:80'
          - 'appwrite-worker-databases:80'
          - 'appwrite-worker-builds:80'
          - 'appwrite-worker-certificates:80'
          - 'appwrite-worker-functions:80'
          - 'appwrite-worker-mails:80'
          - 'appwrite-worker-messaging:80'
EOF
```

Create alert rules:

```bash
# Create alerts.yml
cat <<'EOF' | ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo tee /opt/monitoring/prometheus/alerts.yml"
groups:
  - name: appwrite_alerts
    interval: 30s
    rules:
      # Appwrite API health check
      - alert: AppwriteAPIDown
        expr: up{job="appwrite-api"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Appwrite API is down"
          description: "Appwrite API has been unreachable for more than 2 minutes"

      # Appwrite Realtime health check
      - alert: AppwriteRealtimeDown
        expr: up{job="appwrite-realtime"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Appwrite Realtime is down"
          description: "Appwrite Realtime service has been unreachable for more than 2 minutes"

      # Database health check
      - alert: MariaDBDown
        expr: up{job="mariadb"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "MariaDB is down"
          description: "MariaDB database has been unreachable for more than 1 minute"

      # Redis health check
      - alert: RedisDown
        expr: up{job="redis"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Redis is down"
          description: "Redis cache has been unreachable for more than 1 minute"

      # High CPU usage
      - alert: HighCPUUsage
        expr: 100 - (avg by(instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > {{monitoring.alertThresholds.cpuUsagePercent}}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High CPU usage detected"
          description: "CPU usage is above {{monitoring.alertThresholds.cpuUsagePercent}}% for more than 5 minutes on {{verbatim}}{{ $labels.instance }}{{/verbatim}}"

      # High memory usage
      - alert: HighMemoryUsage
        expr: (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > {{monitoring.alertThresholds.memoryUsagePercent}}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage detected"
          description: "Memory usage is above {{monitoring.alertThresholds.memoryUsagePercent}}% for more than 5 minutes"

      # High disk usage
      - alert: HighDiskUsage
        expr: (1 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"})) * 100 > {{monitoring.alertThresholds.diskUsagePercent}}
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "High disk usage detected"
          description: "Disk usage is above {{monitoring.alertThresholds.diskUsagePercent}}% on root partition"

      # Slow response times
      - alert: SlowResponseTime
        expr: histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) > {{divide monitoring.alertThresholds.responseTimeMs 1000}}
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Slow API response times"
          description: "95th percentile response time is above {{monitoring.alertThresholds.responseTimeMs}}ms"

      # Worker failures
      - alert: WorkerFailures
        expr: rate(worker_failures_total[5m]) > 0.1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High worker failure rate"
          description: "Worker failure rate is above 0.1/second"
EOF
```

Deploy Prometheus container:

```bash
ssh -i {{security.sshKeyPath}} root@$VPS_IP "
  docker run -d \
    --name prometheus \
    --network appwrite \
    -p {{monitoring.prometheusPort}}:9090 \
    -v /opt/monitoring/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml \
    -v /opt/monitoring/prometheus/alerts.yml:/etc/prometheus/alerts/alerts.yml \
    -v /var/lib/prometheus:/prometheus \
    --restart unless-stopped \
    prom/prometheus:latest \
    --config.file=/etc/prometheus/prometheus.yml \
    --storage.tsdb.path=/prometheus \
    --storage.tsdb.retention.time={{monitoring.retentionDays}}d \
    --web.console.libraries=/usr/share/prometheus/console_libraries \
    --web.console.templates=/usr/share/prometheus/consoles
"
```

