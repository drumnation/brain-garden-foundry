### Step 4: Deploy Alertmanager (Alert Routing)

Create Alertmanager configuration:

```bash
cat <<'EOF' | ssh -i {{security.sshKeyPath}} root@$VPS_IP "sudo tee /opt/monitoring/alertmanager/alertmanager.yml"
global:
  resolve_timeout: 5m
{{#if monitoring.smtp}}
  smtp_smarthost: '{{monitoring.smtp.host}}:{{monitoring.smtp.port}}'
  smtp_from: '{{monitoring.smtp.from}}'
  smtp_auth_username: '{{monitoring.smtp.username}}'
  smtp_auth_password: '{{monitoring.smtp.password}}'
{{/if}}

# Route configuration
route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h
  receiver: 'default'

  routes:
    # Critical alerts go to multiple channels
    - match:
        severity: critical
      receiver: 'critical-alerts'
      continue: true

    # Warning alerts go to email only
    - match:
        severity: warning
      receiver: 'warning-alerts'

# Receivers (notification channels)
receivers:
  - name: 'default'
    email_configs:
      - to: '{{monitoring.alertEmail}}'
        headers:
          Subject: '[{{projectName}}] {{verbatim}}{{ .GroupLabels.alertname }}{{/verbatim}}'

  - name: 'critical-alerts'
    email_configs:
      - to: '{{monitoring.alertEmail}}'
        headers:
          Subject: '[CRITICAL] {{projectName}} Alert: {{verbatim}}{{ .GroupLabels.alertname }}{{/verbatim}}'
{{#if monitoring.slackWebhook}}
    slack_configs:
      - api_url: '{{monitoring.slackWebhook}}'
        channel: '#{{monitoring.slackChannel}}'
        title: '[CRITICAL] {{verbatim}}{{ .GroupLabels.alertname }}{{/verbatim}}'
        text: '{{verbatim}}{{ range .Alerts }}{{ .Annotations.description }}{{ end }}{{/verbatim}}'
{{/if}}
{{#if monitoring.pagerdutyKey}}
    pagerduty_configs:
      - service_key: '{{monitoring.pagerdutyKey}}'
        description: '{{verbatim}}{{ .GroupLabels.alertname }}{{/verbatim}}'
{{/if}}

  - name: 'warning-alerts'
    email_configs:
      - to: '{{monitoring.alertEmail}}'
        headers:
          Subject: '[WARNING] {{projectName}} Alert: {{verbatim}}{{ .GroupLabels.alertname }}{{/verbatim}}'
EOF
```

