## Testing Strategy

### End-to-End Test

```bash
# Test 1: Create preview project manually
curl -X POST "https://{{domain.appwriteSubdomain}}.{{domain.rootDomain}}/v1/projects" \
  -H "X-Appwrite-Project: {{previewEnvironments.adminProjectId}}" \
  -H "X-Appwrite-Key: $ADMIN_API_KEY" \
  -H "Content-Type: application/json" \
  -d '{"projectId": "test-pr-999", "name": "Test Preview", "teamId": "unique()"}'

# Test 2: Create DNS record
{{#if (eq dnsProvider.provider "cloudflare")}}
curl -X POST "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records" \
  -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"type":"CNAME","name":"pr-999.{{domain.appwriteSubdomain}}","content":"{{domain.appwriteSubdomain}}.{{domain.rootDomain}}","ttl":1}'
{{/if}}
{{#if (eq dnsProvider.provider "route53")}}
ZONE_ID=$(aws route53 list-hosted-zones --query "HostedZones[?Name=='{{domain.rootDomain}}.'].Id" --output text | cut -d'/' -f3)
cat > /tmp/test-dns.json <<EOF
{
  "Changes": [{
    "Action": "UPSERT",
    "ResourceRecordSet": {
      "Name": "pr-999.{{domain.appwriteSubdomain}}.{{domain.rootDomain}}",
      "Type": "CNAME",
      "TTL": 300,
      "ResourceRecords": [{"Value": "{{domain.appwriteSubdomain}}.{{domain.rootDomain}}"}]
    }
  }]
}
EOF
aws route53 change-resource-record-sets --hosted-zone-id $ZONE_ID --change-batch file:///tmp/test-dns.json
{{/if}}
{{#if (eq dnsProvider.provider "digitalocean")}}
curl -X POST "https://api.digitalocean.com/v2/domains/{{domain.rootDomain}}/records" \
  -H "Authorization: Bearer $DIGITALOCEAN_API_TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"type":"CNAME","name":"pr-999.{{domain.appwriteSubdomain}}","data":"{{domain.appwriteSubdomain}}.{{domain.rootDomain}}.","ttl":300}'
{{/if}}

# Test 3: Verify project accessible
curl -f "https://{{domain.appwriteSubdomain}}.{{domain.rootDomain}}/v1/health/version" \
  -H "X-Appwrite-Project: test-pr-999"

# Test 4: Delete project
curl -X DELETE "https://{{domain.appwriteSubdomain}}.{{domain.rootDomain}}/v1/projects/test-pr-999" \
  -H "X-Appwrite-Project: {{previewEnvironments.adminProjectId}}" \
  -H "X-Appwrite-Key: $ADMIN_API_KEY"

# Test 5: Delete DNS record
{{#if (eq dnsProvider.provider "cloudflare")}}
DNS_RECORD_ID=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records?name=pr-999.{{domain.appwriteSubdomain}}.{{domain.rootDomain}}" \
  -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" | jq -r '.result[0].id')
curl -X DELETE "https://api.cloudflare.com/client/v4/zones/$CLOUDFLARE_ZONE_ID/dns_records/$DNS_RECORD_ID" \
  -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN"
{{/if}}
{{#if (eq dnsProvider.provider "route53")}}
cat > /tmp/test-dns-delete.json <<EOF
{
  "Changes": [{
    "Action": "DELETE",
    "ResourceRecordSet": {
      "Name": "pr-999.{{domain.appwriteSubdomain}}.{{domain.rootDomain}}",
      "Type": "CNAME",
      "TTL": 300,
      "ResourceRecords": [{"Value": "{{domain.appwriteSubdomain}}.{{domain.rootDomain}}"}]
    }
  }]
}
EOF
aws route53 change-resource-record-sets --hosted-zone-id $ZONE_ID --change-batch file:///tmp/test-dns-delete.json
{{/if}}
{{#if (eq dnsProvider.provider "digitalocean")}}
RECORD_ID=$(curl -s -X GET "https://api.digitalocean.com/v2/domains/{{domain.rootDomain}}/records?name=pr-999.{{domain.appwriteSubdomain}}" \
  -H "Authorization: Bearer $DIGITALOCEAN_API_TOKEN" | jq -r '.domain_records[0].id')
curl -X DELETE "https://api.digitalocean.com/v2/domains/{{domain.rootDomain}}/records/$RECORD_ID" \
  -H "Authorization: Bearer $DIGITALOCEAN_API_TOKEN"
{{/if}}
```

