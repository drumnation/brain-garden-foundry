```

{{#if previewEnvironments.cleanupScript}}
### Cleanup Orphaned Projects

```bash
# Create cleanup script
cat > /opt/appwrite/cleanup-preview-projects.sh << 'EOF'
#!/bin/bash
# Delete preview projects older than {{previewEnvironments.retentionPolicy}} days

ADMIN_PROJECT_ID="{{previewEnvironments.adminProjectId}}"
ADMIN_API_KEY="$ADMIN_API_KEY"
ENDPOINT="https://{{domain.appwriteSubdomain}}.{{domain.rootDomain}}/v1"

# Get all preview projects
PROJECTS=$(curl -s -X GET "$ENDPOINT/projects?queries[]=startsWith('id','pr-')" \
  -H "X-Appwrite-Project: $ADMIN_PROJECT_ID" \
  -H "X-Appwrite-Key: $ADMIN_API_KEY" | jq -r '.projects[] | select(.createdAt < (now - {{multiply previewEnvironments.retentionPolicy 86400}})) | .id')

# Delete old projects
for PROJECT_ID in $PROJECTS; do
  echo "Deleting project: $PROJECT_ID"
  curl -X DELETE "$ENDPOINT/projects/$PROJECT_ID" \
    -H "X-Appwrite-Project: $ADMIN_PROJECT_ID" \
    -H "X-Appwrite-Key: $ADMIN_API_KEY"
done
EOF

chmod +x /opt/appwrite/cleanup-preview-projects.sh

# Schedule {{previewEnvironments.cleanupSchedule}} cleanup
(crontab -l 2>/dev/null; echo "{{previewEnvironments.cleanupCron}} /opt/appwrite/cleanup-preview-projects.sh") | crontab -
```
{{/if}}

