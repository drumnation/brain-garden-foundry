{
  "projectName": "my-project",
  "domain": {
    "rootDomain": "example.com",
    "appwriteSubdomain": "appwrite"
  },
  "vpsProvider": {
    "provider": "vultr",
    "apiKey": "$VULTR_API_KEY",
    "region": "ewr",
    "plan": "vc2-4c-8gb",
    "os": "387"
  },
  "dnsProvider": {
    "provider": "cloudflare",
    "apiToken": "$CLOUDFLARE_API_TOKEN",
    "zoneId": "your_zone_id_here"
  },
  "appwrite": {
    "version": "1.5.7",
    "adminEmail": "admin@example.com",
    "adminPassword": "$APPWRITE_ADMIN_PASSWORD"
  },
  "deploymentEnvironments": [
    {
      "name": "production",
      "branch": "main",
      "requiresApproval": true,
      "projectId": "production",
      "apiKey": "$APPWRITE_API_KEY_production"
    },
    {
      "name": "staging",
      "branch": "staging",
      "requiresApproval": false,
      "projectId": "staging",
      "apiKey": "$APPWRITE_API_KEY_staging"
    }
  ],
  "previewEnvironments": {
    "enabled": true,
    "maxEnvironments": 5,
    "autoDelete": true,
    "deleteAfterDays": 3
  },
  "monitoring": {
    "enabled": true,
    "prometheus": {
      "retentionDays": 15,
      "scrapeInterval": "15s"
    },
    "grafana": {
      "adminPassword": "$GRAFANA_ADMIN_PASSWORD"
    },
    "alerting": {
      "email": "alerts@example.com",
      "slackWebhook": "$SLACK_WEBHOOK_URL",
      "pagerDutyKey": "$PAGERDUTY_SERVICE_KEY"
    }
  },
  "security": {
    "sshPort": 22,
    "firewallRules": [
      { "protocol": "tcp", "port": 22, "source": "0.0.0.0/0", "description": "SSH" },
      { "protocol": "tcp", "port": 80, "source": "0.0.0.0/0", "description": "HTTP" },
      { "protocol": "tcp", "port": 443, "source": "0.0.0.0/0", "description": "HTTPS" }
    ],
    "ssl": {
      "provider": "letsencrypt",
      "email": "ssl@example.com"
    }
  },
  "github": {
    "repository": "owner/repo",
    "actionsSecrets": {
      "vpsApiKey": "VULTR_API_KEY",
      "dnsApiToken": "CLOUDFLARE_API_TOKEN",
      "dnsZoneId": "CLOUDFLARE_ZONE_ID"
    }
  },
  "backup": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "retention": 7,
    "destination": "s3://backup-bucket/appwrite/"
  }
}